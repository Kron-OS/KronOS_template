{
  "realm": "kronos",
  "displayName": "KronOS",
  "displayNameHtml": "<b>KronOS</b>",
  "enabled": true,
  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "sslRequired": "external",
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "attributes": {
    "acr.loa.map": "{\"aal1\":1,\"aal2\":2}"
  },
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "org-admin",
        "description": "Organization administrator — full control over org users, cases, and settings",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "case-lead",
        "description": "Case lead investigator — can create cases and manage evidence",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "analyst",
        "description": "Forensic analyst — can upload evidence and view timelines",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "read-only",
        "description": "Read-only viewer — can view cases, evidence, and timelines",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "kronos-frontend",
      "name": "KronOS Frontend",
      "description": "KronOS frontend single-page application",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost/*",
        "http://localhost:4173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost",
        "http://localhost:4173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost/*"
      },
      "protocolMappers": [
        {
          "name": "kronos-backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "kronos-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "kronos-backend",
      "name": "KronOS Backend",
      "description": "KronOS FastAPI backend service account",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "kronos-backend-secret",
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "opensearch-dashboards",
      "name": "OpenSearch Dashboards",
      "description": "OpenSearch Dashboards OIDC client for timeline embed",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "opensearch-dashboards-secret",
      "redirectUris": [
        "http://localhost:5601/*"
      ],
      "webOrigins": [
        "http://localhost:5601"
      ]
    },
    {
      "clientId": "kronos-attest",
      "name": "KronOS Attest CLI",
      "description": "Read-only CLI client for offline audit verification",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false
    }
  ],
  "clientScopes": [
    {
      "name": "kronos-roles",
      "description": "Includes realm roles in the token",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "organization",
      "description": "Organization context for multi-tenancy",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "organization-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-membership-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "organization",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "addOrganizationId": "true",
            "addOrganizationAttributes": "false"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "roles",
    "profile",
    "email",
    "web-origins",
    "acr",
    "kronos-roles",
    "organization"
  ],
  "defaultOptionalClientScopes": [
    "offline_access",
    "address",
    "phone",
    "microprofile-jwt"
  ],
  "users": [
    {
      "id": "10000000-0000-4000-8000-000000000001",
      "username": "admin",
      "email": "admin@kronos.dev",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "DevAdmin#2026",
          "temporary": false
        }
      ],
      "realmRoles": ["org-admin"],
      "requiredActions": []
    },
    {
      "id": "10000000-0000-4000-8000-000000000002",
      "username": "analyst",
      "email": "analyst@kronos.dev",
      "firstName": "Test",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "DevAnalyst#2026",
          "temporary": false
        }
      ],
      "realmRoles": ["analyst"],
      "requiredActions": []
    },
    {
      "id": "10000000-0000-4000-8000-000000000003",
      "username": "case-lead",
      "email": "caselead@kronos.dev",
      "firstName": "Case",
      "lastName": "Lead",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "DevCaseLead#2026",
          "temporary": false
        }
      ],
      "realmRoles": ["case-lead"],
      "requiredActions": []
    }
  ],
  "organizations": [
    {
      "id": "20000000-0000-4000-8000-000000000001",
      "name": "KronOS Dev",
      "alias": "kronos-dev",
      "enabled": true,
      "description": "Default development organization",
      "domains": [
        {
          "name": "kronos.dev",
          "verified": true
        }
      ],
      "members": []
    }
  ],
  "passwordPolicy": "length(12) and notUsername and notEmail",
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "smtpServer": {}
}
