# KronOS environment variables — copy to .env and fill in production values
# NEVER commit the actual .env file

# Database
POSTGRES_DB=kronos
POSTGRES_USER=kronos
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://kronos:changeme_in_production@postgres:5432/kronos

# Redis
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://:changeme_in_production@redis:6379/0

# MinIO / S3 object storage
MINIO_ROOT_USER=kronos_minio
MINIO_ROOT_PASSWORD=changeme_in_production
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=kronos_minio
MINIO_SECRET_KEY=changeme_in_production

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_in_production
KEYCLOAK_HOSTNAME=keycloak.kronos.example
KEYCLOAK_ISSUER=http://keycloak:8080/realms/kronos
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/kronos/protocol/openid-connect/certs

# Vault / KMS
VAULT_TOKEN=changeme_in_production
VAULT_ADDR=http://vault:8200

# Application
KRONOS_SECRET_KEY=changeme_in_production_must_be_32_bytes_min
KRONOS_ENV=production

# RFC 3161 Timestamping
TSA_URL=http://tsa:318

# ClamAV
CLAMD_HOST=clamav
CLAMD_PORT=3310
